# 이 파일을 복사해서 .env 로 만들고 값을 채우세요 (.env 는 git 에 안 올라감)
#
#   cp .env.example .env
#
# ⚠️ PRIVATE_KEY 는 반드시 "테스트넷 전용" 새 지갑의 키만 넣으세요.
#    실제 돈이 든 메인 지갑 키는 절대 넣지 마세요.

# 지갑 개인키 (0x 포함)
PRIVATE_KEY=0x여기에_테스트넷_지갑_개인키

# Robinhood Chain 테스트넷 RPC (public, rate-limited)
RPC_URL=https://rpc.testnet.chain.robinhood.com
